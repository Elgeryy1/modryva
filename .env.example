# "production" closes the /simulate debug endpoint and enforces
# TELEGRAM_WEBHOOK_SECRET on the real webhook. Use "development" only for a
# local, non-Docker `pnpm dev` workflow.
NODE_ENV=production
PORT=3000
API_PORT=3001
BOT_PORT=3002
WORKER_CONCURRENCY=2
DATABASE_URL=postgresql://superbot:superbot@localhost:5432/superbot?schema=public
REDIS_URL=redis://localhost:6379
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_BOT_USERNAME=superbot_bot
TELEGRAM_APP_URL=http://localhost:3003
TELEGRAM_WEBHOOK_BASE_URL=http://localhost:3002
SUPERBOT_OWNER_TELEGRAM_ID=123456789
SUPERBOT_PLATFORM_ADMIN_TELEGRAM_IDS=123456789,987654321
SESSION_SECRET=replace-me-too
MANAGED_BOT_TOKEN_KEY=replace-me-with-32-random-chars
LOG_LEVEL=info

# --- AI free pool ---
AI_ENABLED=0
AI_GROQ_ENABLED=0
AI_GROQ_API_KEY_1=
AI_GROQ_API_KEY_2=
AI_GROQ_API_KEY_3=
AI_GROQ_API_KEY_4=
AI_GROQ_API_KEY_5=
AI_GROQ_API_KEYS=
AI_GROQ_MODEL=llama-3.1-8b-instant
AI_GROQ_KEY_COOLDOWN_SECONDS=60
AI_GEMINI_ENABLED=0
AI_GEMINI_PROJECT_1_API_KEY=
AI_GEMINI_PROJECT_2_API_KEY=
AI_GEMINI_PROJECT_3_API_KEY=
AI_GEMINI_PROJECT_4_API_KEY=
AI_GEMINI_PROJECT_5_API_KEY=
AI_GEMINI_API_KEYS=
AI_GEMINI_MODEL=gemini-2.5-flash-lite
AI_GEMINI_KEY_COOLDOWN_SECONDS=90
AI_OPENROUTER_ENABLED=0
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=openrouter/free
AI_OPENROUTER_ALLOW_PAID_MODELS=0
AI_PROVIDER_ORDER=groq,gemini,openrouter
AI_MAX_REQUESTS_PER_USER_DAY=20
AI_MAX_REQUESTS_PER_GROUP_DAY=200
AI_MAX_TOKENS_PER_REQUEST=1200
AI_MAX_INPUT_CHARS=8000
AI_CACHE_TTL_SECONDS=3600
AI_PRIVACY_MODE=normal
TELEGRAM_AI_GUEST_MODE_EXPECTED=1
TELEGRAM_AI_INLINE_MODE_EXPECTED=1
TELEGRAM_AI_STREAM_DRAFTS=1
TELEGRAM_AI_USE_SEND_CHAT_ACTION=1
# Reserved for a future opt-in "answer inline with AI" mode. Must stay 0: Inline
# Mode gets one query per keystroke and must never trigger an AI call.
AI_INLINE_USE_AI_DIRECTLY=0
AI_INLINE_CACHE_TTL_SECONDS=300
AI_INLINE_MIN_QUERY_CHARS=1

# --- Guardian Verification (join-request camera verification, Bot API 10.1) ---
# See docs/GUARDIAN_TELEGRAM_TEST.md for the full setup runbook. Reuses
# TELEGRAM_BOT_TOKEN / TELEGRAM_APP_URL / DATABASE_URL / REDIS_URL above.
GUARDIAN_ENABLED=0
# The photo-mode gesture/face/age judge reuses the SAME AI_GEMINI_*/AI_GROQ_*
# keys as the chat AI below (no separate credentials) — this flag is the
# explicit, independent switch for it, so turning chat AI on never silently
# re-enables Guardian's vision judge too.
GUARDIAN_VISION_JUDGE_ENABLED=0
# Optional: defaults to ${TELEGRAM_APP_URL}/guardian/verify when unset.
GUARDIAN_MINIAPP_URL=
# Generate with: node scripts/generate-guardian-secrets.mjs
GUARDIAN_SESSION_SECRET=
GUARDIAN_MEDIA_ENCRYPTION_KEY=
GUARDIAN_DEFAULT_STAFF_CHAT_ID=
GUARDIAN_DEFAULT_STAFF_THREAD_ID=
GUARDIAN_STORAGE_DRIVER=local
GUARDIAN_STORAGE_PATH=./data/guardian-media
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
# Reserved for a future external analysis microservice (not wired yet).
AI_SERVICE_URL=
AI_SERVICE_API_KEY=
GUARDIAN_RETENTION_HOURS=72
GUARDIAN_MAX_UPLOAD_MB=25
# NEVER set to 1 in production — enables the fixture-only dev harness.
GUARDIAN_TEST_MODE=0

# --- Stable named tunnel (optional; see docs/stable-tunnel-runbook.md) ---
# Quick tunnel (default) rotates its URL on every restart. For a URL that never
# changes, create a named Cloudflare tunnel (needs a Cloudflare account + a domain
# on Cloudflare) and fill these three, then run:
#   docker compose --profile tunnel-named up -d
CLOUDFLARE_TUNNEL_TOKEN=
# With the named tunnel set TELEGRAM_APP_URL to your fixed hostname and pin it so
# the bot ignores the rotating /state file:
#   TELEGRAM_APP_URL=https://app.tudominio.com
#   TELEGRAM_APP_URL_PINNED=1
TELEGRAM_APP_URL_PINNED=
