{
  "name": "superbot",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "dev": "node scripts/run.mjs dev",
    "build": "node scripts/run.mjs build",
    "lint": "node node_modules/@biomejs/biome/bin/biome check . && node scripts/lint-copy.mjs",
    "lint:copy": "node scripts/lint-copy.mjs",
    "format": "node node_modules/@biomejs/biome/bin/biome format --write .",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:integration": "node node_modules/vitest/vitest.mjs run **/*.integration.test.ts",
    "typecheck": "node scripts/run.mjs typecheck",
    "db:drift-check": "node node_modules/prisma/build/index.js migrate diff --from-migrations packages/data/prisma/migrations --to-schema-datamodel packages/data/prisma/schema.prisma --shadow-database-url \"$SHADOW_DATABASE_URL\" --exit-code",
    "db:generate": "node scripts/run.mjs db:generate",
    "db:push": "node scripts/run.mjs db:push",
    "db:migrate": "node scripts/run.mjs db:migrate",
    "db:deploy": "node scripts/run.mjs db:deploy",
    "prod:check": "node scripts/check-production-env.mjs",
    "guardian:doctor": "node scripts/guardian-doctor.mjs",
    "guardian:secrets": "node scripts/generate-guardian-secrets.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@nestjs/testing": "^11.1.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^6.0.3",
    "dotenv": "^16.6.1",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-fastify": "^11.1.9",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.42.0",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "pino": "^9.8.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "supertest": "^7.1.4",
    "zod": "^4.0.17",
    "typescript": "^5.9.2",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
