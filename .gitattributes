# Normaliza finales de línea. Cierra la deuda anotada en AUDIT-CODE-FULL-2026-07-16.md §10:
# el repo se edita desde Windows y se ejecuta en contenedores Linux, y sin esto los diffs
# se llenan de ruido CRLF y las claves de cifrado leídas de ficheros se corrompen
# (gotcha real ya documentado: la clave del contenedor con CRLF invalida los tokens).
* text=auto eol=lf

# Ficheros que DEBEN conservar CRLF o son de Windows
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Scripts que se ejecutan dentro de contenedores o en el NAS: LF obligatorio
*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binarios: nunca tocar
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.dump   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.mp4    binary
*.webm   binary

# Generados: no contar en las estadísticas de lenguaje ni ensuciar los diffs
pnpm-lock.yaml                       linguist-generated=true -diff
packages/data/prisma/schema.prisma   -diff=off
modules/games/src/trivia-bank.ts     linguist-generated=true -diff
