// --- Guardian Verification: per-chat config + join-request verification flow ---

model GuardianVerificationSettings {
  id            String       @id @default(cuid())
  tenantId      String
  chatId        String       @unique
  enabled       Boolean      @default(false)
  mode          GuardianMode @default(off)
  // Raw Telegram chat id of the STAFF chat/channel (not necessarily a chat we
  // track in `Chat` — often a private staff-only channel the bot posts to).
  staffChatId   BigInt?
  staffThreadId Int?

  captureMode         GuardianCaptureMode         @default(video_with_fallback)
  challengeDifficulty GuardianChallengeDifficulty @default(normal)
  // Array of enabled challenge kinds (face/hands/sequences); null = defaults.
  enabledChallenges   Json?

  maxAttempts         Int @default(3)
  sessionTtlSeconds   Int @default(600)
  mediaRetentionHours Int @default(72)

  autoApproveThreshold  Float @default(0.85)
  manualReviewThreshold Float @default(0.55)
  livenessMinimum       Float @default(0.6)
  gestureMinimum        Float @default(0.6)
  replayRiskMaximum     Float @default(0.4)
  syntheticRiskMaximum  Float @default(0.4)

  requireSingleFace Boolean @default(true)
  estimateAge       Boolean @default(false)
  minimumAge        Int?
  maximumAge        Int?
  // 1 = single photo (default). 2 = double verification: a second photo with
  // a DIFFERENT requested gesture, cross-checked by AI to confirm it's the
  // same person as the first — never silently skipped when requested (see
  // decision-engine.ts's samePersonStatus gate).
  requiredPhotos Int @default(1)

  // ISO 3166-1 alpha-2 codes (e.g. ["ES","PT"]). Empty = no restriction.
  // Resolved from the person's IP (via Cloudflare's CF-IPCountry header —
  // never phone number or GPS location) captured silently on the Mini App's
  // first request, before any consent/photo UI — see decision-engine.ts's
  // countryCode gate and GuardianVerifyController.getSession.
  allowedCountries String[] @default([])

  allowAutomaticDecline    Boolean @default(false)
  sendApprovedCasesToStaff Boolean @default(true)
  protectStaffContent      Boolean @default(true)
  locale                   String  @default("es")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("guardian_verification_settings")
}

// One row per Telegram `chat_join_request`. Lifecycle: pending -> miniapp_opened
// -> capturing -> analyzing -> (resolved | awaiting_retry -> capturing again) ->
// expired/cancelled. `chatId`/`telegramUserId` etc. are plain indexed columns
// (no Prisma relation), matching the CaptchaConfig/CaptchaSession convention
// used elsewhere in this schema.
model VerificationSession {
  id             String @id @default(cuid())
  tenantId       String
  chatId         String
  telegramChatId BigInt
  telegramUserId BigInt
  // Private chat id with the user, when known (e.g. to DM a result). Distinct
  // from telegramUserId because a user id is not always usable as a chat id
  // for bots that never received a /start in DM.
  userChatId     BigInt?

  // AES-256-GCM ciphertext (iv+tag packed, base64) of the Bot API
  // chat_join_request query_id. Only needed to answer the FIRST
  // answerChatJoinRequestQuery call; nulled out once that call succeeds. Manual
  // staff decisions after an initial `queue` answer use the already-implemented
  // approveChatJoinRequest/declineChatJoinRequest (chat_id + user_id) instead —
  // see docs/GUARDIAN_TELEGRAM_TEST.md for why.
  joinRequestQueryIdEncrypted String?

  username        String?
  firstName       String?
  lastName        String?
  languageCode    String?
  inviteLinkName  String?
  // ISO 3166-1 alpha-2, resolved from the person's IP (Cloudflare's
  // CF-IPCountry) on the Mini App's very first request and pinned here —
  // never re-derived later, so enabling a VPN mid-flow can't change it.
  countryCode     String?

  status           GuardianSessionStatus @default(pending)
  decision         GuardianDecision?
  decisionReason   String?
  // Structured explanation: decision codes, signals, thresholds, policy
  // version — never just a free-text summary, so STAFF can audit the "why".
  decisionPayload  Json?
  // Snapshot of the chat's GuardianMode at session creation, so a later config
  // change can't reinterpret an in-flight session under a different policy.
  mode             GuardianMode

  challengeDefinition Json
  // Single-use nonce embedded in the challenge; a replayed/edited client
  // submission that doesn't match is rejected.
  challengeNonce      String @unique
  // SHA-256 hash of the opaque bearer token handed to the Mini App URL. The
  // raw token is never persisted.
  sessionTokenHash    String @unique

  expiresAt    DateTime
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  resolvedAt   DateTime?

  staffChatId            BigInt?
  staffMessageId         Int?
  staffReportMessageId   Int?
  // When the STAFF report message becomes eligible for retention deletion.
  // Stamped at send time so the cleanup worker is driven by the session (photo
  // and no-media text reports alike), never by the mutable media delete cursor.
  staffReportDeleteAfter DateTime?

  // Optimistic lock: every state transition (session update, staff decision,
  // Telegram answer) increments this and checks it in the WHERE clause so two
  // concurrent resolutions (e.g. auto-decision race with a staff tap) can't
  // both "win".
  version Int @default(1)

  // Deterministic hash of (chatId, telegramUserId) while a session is ACTIVE;
  // set back to null on resolution/expiry so a later join request can start a
  // fresh session. The @unique constraint is what actually prevents a second
  // concurrent session for the same person in the same chat (Postgres allows
  // unlimited NULLs in a unique column, so resolved sessions don't collide).
  idempotencyKey String? @unique

  @@index([tenantId, chatId, status])
  @@index([tenantId, telegramUserId])
  @@index([expiresAt])
  @@index([staffReportDeleteAfter])
  @@map("verification_sessions")
}

model VerificationAttempt {
  id            String   @id @default(cuid())
  sessionId     String
  attemptNumber Int
  captureType   String
  startedAt     DateTime?
  finishedAt    DateTime?
  // On-device (client) analysis summary — guidance only, never authoritative.
  clientEvidence Json?
  analysisStatus GuardianProviderStatus @default(not_evaluated)
  failureReason  String?
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@unique([sessionId, attemptNumber])
  @@map("verification_attempts")
}

model VerificationMedia {
  id                  String    @id @default(cuid())
  sessionId           String
  attemptId           String?
  objectStorageKey    String
  thumbnailStorageKey String?
  mimeDetected        String?
  mimeDeclared        String?
  sizeBytes           Int?
  width               Int?
  height              Int?
  durationMs          Int?
  fps                 Float?
  codec               String?
  sha256              String
  perceptualHash      String?
  createdAt           DateTime  @default(now())
  deleteAfter         DateTime
  deletedAt           DateTime?

  @@index([sessionId])
  @@index([sha256])
  @@index([deleteAfter])
  @@map("verification_media")
}

model VerificationAnalysis {
  id        String @id @default(cuid())
  attemptId String @unique

  faceCount      Int?
  faceConfidence Float?

  gestureRequested String?
  gestureDetected  String?
  gestureScore     Float?

  headMovementRequested String?
  headMovementDetected  String?
  headMovementScore     Float?

  blinkRequested Boolean?
  blinkDetected  Boolean?

  livenessScore  Float?
  livenessStatus GuardianProviderStatus?

  replayRisk         Float?
  screenReplayRisk   Float?
  syntheticMediaRisk Float?
  syntheticStatus    GuardianProviderStatus?

  provenanceStatus GuardianProvenanceStatus?

  estimatedAgeMin Int?
  estimatedAgeMax Int?
  ageConfidence   Float?
  ageStatus       GuardianProviderStatus?

  qualityScore  Float?
  lightingScore Float?

  hardFailures Json?
  warnings     Json?
  modelVersions Json?

  analysisDurationMs Int?
  // Full technical report handed to STAFF as a downloadable JSON — every field
  // above is derived from this, kept in sync at write time.
  rawTechnicalReport Json?
  createdAt          DateTime @default(now())

  @@map("verification_analyses")
}

model StaffDecision {
  id                  String              @id @default(cuid())
  sessionId           String
  moderatorTelegramId BigInt
  action              GuardianStaffAction
  reason              String?
  createdAt           DateTime            @default(now())

  @@index([sessionId])
  @@map("staff_decisions")
}

// --- Casino chip economy (virtual, non-cashable) ---

model ChipWallet {
  id             String   @id @default(cuid())
  tenantId       String
  telegramUserId BigInt
  balance        Int      @default(0)
  // Provably-fair commit-reveal seed pair. serverSeed is SECRET until rotation;
  // serverSeedHash is the public commit shown before any bet. nonce increments
  // per bet so every outcome is reproducible from (serverSeed, clientSeed, nonce).
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, telegramUserId])
  @@index([tenantId])
  @@map("chip_wallets")
}

model ChipLedger {
  id             String   @id @default(cuid())
  tenantId       String
  telegramUserId BigInt
  delta          Int
  reason         String
  // refId links a row to its origin (betId, or a UTC day for the daily bonus).
  // The composite unique makes idempotent grants (daily/bonus) safe.
  refId          String?
  // chargeId is the Telegram Stars idempotency key (one credit per purchase).
  chargeId       String?  @unique
  createdAt      DateTime @default(now())

  @@unique([tenantId, telegramUserId, reason, refId])
  @@index([tenantId, telegramUserId])
  @@map("chip_ledger")
}

model CasinoDuel {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  challengerId   BigInt
  challengerName String?
  stake          Int
  status         String   @default("open") // open | rolling | settled | cancelled
  opponentId     BigInt?
  winnerId       BigInt?
  createdAt      DateTime @default(now())

  @@index([tenantId, status])
  @@map("casino_duels")
}

model CasinoBet {
  id             String   @id @default(cuid())
  tenantId       String
  telegramUserId BigInt
  game           String // crash | mines | blackjack
  stake          Int
  status         String   @default("open") // open | settled
  serverSeed     String
  serverSeedHash String
  clientSeed     String
  nonce          Int
  state          Json
  payout         Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([tenantId, telegramUserId, status])
  @@map("casino_bets")
}

// Progressive jackpot: one growing pot per tenant. Each bet skims a small rake
// into it (see ChipRepository.placeBet); a rare provably-fair roll awards it.
model Jackpot {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  amount    Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("jackpots")
}

// Weekly casino tournament. Score = net chips during the ISO-week window
// (derived from ChipLedger, not stored). Lazily settled on first read after the
// window ends: top players are paid from prizePool (funded by the bet rake).
model Tournament {
  id        String    @id @default(cuid())
  tenantId  String
  period    String // ISO week, e.g. "2026-W27"
  startsAt  DateTime
  endsAt    DateTime
  status    String    @default("open") // open | settled
  prizePool Int       @default(0)
  winners   Json? // [{ telegramUserId, prize, net }] set at settlement
  createdAt DateTime  @default(now())
  settledAt DateTime?
  // Set only after every winner's credit() succeeded — separates "claimed for
  // settlement" (status) from "actually paid", so a crash mid-payout can be
  // resumed instead of stranding the remaining winners' prizes forever.
  payoutsCompletedAt DateTime?

  @@unique([tenantId, period])
  @@map("tournaments")
}

