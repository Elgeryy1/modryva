  @@index([tenantId, status, createdAt])
  @@index([tenantId, appellantTelegramId])
  @@map("d1_appeals")
}

model AutomationRule {
  id           String   @id @default(cuid())
  tenantId     String
  chatId       String
  name         String
  triggerKind  String
  triggerValue String
  actionKind   String
  actionValue  String?
  active       Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, chatId, active])
  @@map("automation_rules")
}

model Mission {
  id          String   @id @default(cuid())
  tenantId    String
  chatId      String
  title       String
  goalKind    String
  goalTarget  Int
  rewardBadge String
  active      Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress MissionProgress[]

  @@index([tenantId, chatId, active])
  @@map("missions")
}

model MissionProgress {
  id             String    @id @default(cuid())
  missionId      String
  telegramUserId BigInt
  progress       Int       @default(0)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, telegramUserId])
  @@index([telegramUserId])
  @@map("mission_progress")
}

model UserBadge {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  telegramUserId BigInt
  badgeKey       String
  title          String
  awardedAt      DateTime @default(now())

  @@unique([tenantId, chatId, telegramUserId, badgeKey])
  @@index([tenantId, chatId, telegramUserId])
  @@map("user_badges")
}

/// Generic rolling log of chat activity, used to power ambient security and
/// community detectors that need a recent-history window (tone shift, hot
/// users, cursed topics, copy-paste spam, etc.) without a bespoke table per
/// detector. `kind` discriminates the event shape; unused fields stay null.
model ChatActivityEvent {
  id              String   @id @default(cuid())
  tenantId        String
  chatId          String
  kind            String
  telegramUserId  BigInt?
  username        String?
  text            String?
  topic           String?
  messageId       BigInt?
  hasLink         Boolean  @default(false)
  hasMention      Boolean  @default(false)
  isReply         Boolean  @default(false)
  repliedToUserId BigInt?
  tensionScore    Float?
  createdAt       DateTime @default(now())

  @@index([tenantId, chatId, createdAt])
  @@index([tenantId, chatId, kind, createdAt])
  @@index([tenantId, chatId, messageId])
  @@map("chat_activity_events")
}

// ─── Wave 2 wiring (guardian-verification branch): security detectors, ECA
// engine, and hidden games. Each model backs one repository under
// packages/data/src/; see that file's docstring for what it's for. No
// relation fields to Tenant/Chat are declared (matching ChatActivityEvent
// above) so these can be appended without touching either model's
// back-relation arrays.

model AdminDecision {
  id         String   @id @default(cuid())
  tenantId   String
  chatId     String
  adminId    BigInt
  action     String
  ruleId     String?
  occurredAt DateTime @default(now())

  @@index([tenantId, chatId, occurredAt])
  @@index([tenantId, adminId])
  @@map("admin_decisions")
}

model KnownAdmin {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  adminId   BigInt
  createdAt DateTime @default(now())

  @@unique([tenantId, chatId, adminId])
  @@index([tenantId, chatId])
  @@map("known_admins")
}

model DomainReputation {
  id          String   @id @default(cuid())
  tenantId    String
  domain      String
  firstSeenAt DateTime @default(now())

  @@unique([tenantId, domain])
  @@map("domain_reputation")
}

model EcaRule {
