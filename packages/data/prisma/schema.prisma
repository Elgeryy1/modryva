  nightMode          Boolean  @default(false)
  nightStart         Int      @default(23)
  nightEnd           Int      @default(7)
  welcomeMute        Boolean  @default(false)
  autoApprove        Boolean  @default(false)
  rtlFilter          Boolean  @default(false)
  cjkFilter          Boolean  @default(false)
  language           String   @default("es")
  // Auto-bans new members already listed in CAS (Combot Anti-Spam), a public
  // shared ban list — same source Rose/Combot use.
  blockKnownSpammers Boolean  @default(false)
  // Modryva "passive mode": master switch to make the bot do ONLY Guardian
  // verification + games in this group (so it can coexist with a dedicated
  // moderation bot like GroupHelp). When on, every autonomous sanction, cleanup
  // and unsolicited message is silenced AND the moderation commands are
  // disabled. The three category flags give granular control when NOT fully
  // passive; they default true so existing groups behave exactly as before.
  passiveMode        Boolean  @default(false)
  autoModeration     Boolean  @default(true)
  autoCleanup        Boolean  @default(true)
