  createdBy    BigInt?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions SpeedRoundAnswer[]

  @@index([tenantId, chatId, status])
  @@map("speed_rounds")
}

model SpeedRoundAnswer {
  id         String   @id @default(cuid())
  roundId    String
