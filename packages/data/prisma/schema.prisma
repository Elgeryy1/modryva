  chatId      String?
  event       String
  conditions  Json
  action      Json
  enabled     Boolean  @default(true)
  cooldownMs  Int?
  expiresAtMs BigInt?
  lastFiredMs BigInt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([chatId])
  @@index([tenantId, event, enabled])
  @@map("eca_rules")
}

model SpeedRound {
  id           String   @id @default(cuid())
  tenantId     String
  chatId       String
  question     String
