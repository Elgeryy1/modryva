generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  suspended
  archived
}

enum ModuleStatus {
  enabled
  disabled
  degraded
}

enum AuditActorType {
  user
  bot
  system
  integration
}

enum SanctionKind {
  ban
  mute
  restrict
  warn
  delete
  lock
}

enum CaptchaMode {
  button
  text
  math
  custom
}

enum PolicyAction {
  allow
  warn
  delete
  mute
  ban
  review
}

// --- Guardian Verification (join-request camera verification) ---

enum GuardianMode {
  off
  manual
  assisted
  auto
  strict
}

enum GuardianCaptureMode {
  photo
  video
  video_with_fallback
}

enum GuardianChallengeDifficulty {
  basic
  normal
  strict
}

enum GuardianSessionStatus {
  pending
  miniapp_opened
  capturing
  analyzing
  awaiting_retry
  resolved
  expired
  cancelled
}

enum GuardianDecision {
  auto_approve
  manual_review
  retry
  auto_decline
  technical_failure
}

// Shared status vocabulary for every pluggable AI provider (liveness, age,
// synthetic-media, provenance). `not_evaluated` = provider not configured at
// all; `unavailable` = configured but the call failed/timed out; `uncertain` =
// the provider ran but could not commit to a verdict. Never fabricate a score
// for `not_evaluated`/`unavailable`/`failed`.
enum GuardianProviderStatus {
  success
  uncertain
  unavailable
  failed
  not_evaluated
}

enum GuardianProvenanceStatus {
  c2pa_valid_ai_declared
  c2pa_valid_other
  c2pa_invalid
  c2pa_not_found
  c2pa_unavailable
}

enum GuardianStaffAction {
  approve
  decline
  retry
  delete_media
  mark_false_positive
  expel
}

enum ManagedBotStatus {
  pending
  active
  suspended
  revoked
  failed
}

enum ManagedBotTemplate {
  community
  creator
  support
  business
  custom
}

enum PlatformRole {
  platform_owner
  promo_admin
  bot_factory_admin
  support_admin
  auditor
}

enum EntitlementKind {
  managed_bot_slot
  pro_trial
  agency_pack
}

enum EntitlementSource {
  promo
  payment
  manual
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  bots         ManagedBot[]
  chats        Chat[]
  users        AppUser[]
  roles        Role[]
  flags        FeatureFlag[]
  modules      ModuleState[]
  auditLogs    AuditLog[]
  security     SecurityAlert[]
  settings     ChatSetting[]
  cases        ModerationCase[]
  memberships  Membership[]
  topics       Topic[]
  roleBindings RoleBinding[]
  promoCodes   PromoCode[]
  entitlements Entitlement[]

  @@map("tenants")
}

model ManagedBot {
  id                          String             @id @default(cuid())
  tenantId                    String
  telegramBotId               BigInt?            @unique
  username                    String             @unique
  displayName                 String
  ownerTelegramId             BigInt?
  template                    ManagedBotTemplate @default(community)
  status                      ManagedBotStatus   @default(active)
  encryptedToken              String?
  tokenFingerprint            String?
  tokenLastRotatedAt          DateTime?
  webhookSecretHash           String?
  plan                        String             @default("free")
  entitlementId               String?
  createdViaPromoRedemptionId String?
  lastActivatedAt             DateTime?
  lastError                   String?
  expiryWarnedAt              DateTime?
  isPrimary                   Boolean            @default(false)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ownerTelegramId])
  @@index([status])
  @@map("managed_bots")
}

model PlatformRoleAssignment {
  id                  String       @id @default(cuid())
  telegramUserId      BigInt
  role                PlatformRole
  grantedByTelegramId BigInt?
  revokedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([telegramUserId])
  @@index([role])
  @@map("platform_role_assignments")
}

model PlatformUserBan {
  id                  String    @id @default(cuid())
  telegramUserId      BigInt    @unique
  reason              String
  bannedByTelegramId  BigInt
  bannedAt            DateTime  @default(now())
  expiresAt           DateTime?
  revokedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([revokedAt])
  @@index([expiresAt])
  @@map("platform_user_bans")
}

model PromoCode {
  id                  String             @id @default(cuid())
  tenantId            String?
  codeHash            String             @unique
  codePrefix          String
  kind                EntitlementKind
  template            ManagedBotTemplate @default(community)
  quantity            Int                @default(1)
  maxUses             Int                @default(1)
  usedCount           Int                @default(0)
  expiresAt           DateTime?
  revokedAt           DateTime?
  note                String?
  createdByTelegramId BigInt
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant      Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions PromoRedemption[]

  @@index([tenantId])
  @@index([createdByTelegramId])
  @@map("promo_codes")
}

model PromoRedemption {
  id                   String   @id @default(cuid())
  promoCodeId          String
  redeemedByTelegramId BigInt
  entitlementId        String
  redeemedAt           DateTime @default(now())

  promoCode   PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  entitlement Entitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, redeemedByTelegramId])
  @@index([redeemedByTelegramId])
  @@map("promo_redemptions")
}

model Entitlement {
  id                  String             @id @default(cuid())
  tenantId            String?
  ownerTelegramId     BigInt
  kind                EntitlementKind
  template            ManagedBotTemplate @default(community)
  quantity            Int                @default(1)
  usedQuantity        Int                @default(0)
  source              EntitlementSource
  sourceRef           String?
  expiresAt           DateTime?
  revokedAt           DateTime?
  createdByTelegramId BigInt?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant      Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions PromoRedemption[]

  @@index([tenantId])
  @@index([ownerTelegramId])
  @@index([kind])
  @@map("entitlements")
}

model AppUser {
  id             String   @id @default(cuid())
  tenantId       String?
  telegramUserId BigInt   @unique
  username       String?
  languageCode   String?
  displayName    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  memberships Membership[]
  preferences UserPreference?
  bindings    RoleBinding[]
  warnings    Warning[]
  sanctions   Sanction[]
  appeals     Appeal[]

  @@index([tenantId])
  @@map("users")
}

model Chat {
  id             String   @id @default(cuid())
  tenantId       String
  telegramChatId BigInt
  type           String
  title          String?
  username       String?
  isForum        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]
  topics      Topic[]
  settings    ChatSetting[]
  modules     ModuleState[]
  cases       ModerationCase[]

  @@unique([tenantId, telegramChatId])
  @@index([tenantId])
  @@map("chats")
}

model Membership {
  id        String    @id @default(cuid())
  tenantId  String
  chatId    String
  userId    String
  role      String    @default("member")
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chat   Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, chatId])
  @@index([tenantId, userId])
  @@map("memberships")
}

model Topic {
  id              String   @id @default(cuid())
  tenantId        String
  chatId          String
  telegramTopicId Int
  title           String?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([chatId, telegramTopicId])
  @@index([tenantId])
  @@map("topics")
}

model UserPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  locale        String   @default("es")
  timezone      String   @default("Europe/Madrid")
  dateFormat    String   @default("dd/MM/yyyy")
  accessibility Json?
  notifications Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bindings RoleBinding[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model RoleBinding {
  id        String    @id @default(cuid())
  tenantId  String
  roleId    String
  userId    String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, roleId])
  @@map("role_bindings")
}

model NativeAdminSnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  chatId     String
  userId     String
  payload    Json
  capturedAt DateTime @default(now())

  @@index([tenantId, chatId])
  @@map("native_admin_snapshots")
}

model Approval {
  id        String   @id @default(cuid())
  tenantId  String
  actorId   String?
  action    String
  status    String   @default("pending")
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("approvals")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  enabled   Boolean  @default(false)
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("feature_flags")
}

model ModuleState {
  id        String       @id @default(cuid())
  tenantId  String
  chatId    String?
  moduleKey String
  status    ModuleStatus @default(disabled)
  version   String?
  config    Json?
  updatedAt DateTime     @updatedAt
  createdAt DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chat   Chat?  @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([tenantId, chatId, moduleKey])
  @@index([tenantId, moduleKey])
  @@map("module_states")
}

model UpdateInbox {
  id          String    @id @default(cuid())
  tenantId    String?
  botKey      String
  updateId    BigInt
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([botKey, updateId])
  @@index([tenantId, botKey])
  @@map("update_inbox")
}

model CallbackInbox {
  id          String    @id @default(cuid())
  tenantId    String?
  callbackId  String    @unique
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@map("callback_inbox")
}

model IdempotencyKey {
  id        String    @id @default(cuid())
  tenantId  String?
  namespace String
  key       String
  payload   Json?
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@unique([namespace, key])
  @@index([tenantId])
  @@map("idempotency_keys")
}

model JobOutbox {
  id        String    @id @default(cuid())
  tenantId  String?
  topic     String
  payload   Json
  state     String    @default("pending")
  runAfter  DateTime?
  lockedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, state])
  @@map("job_outbox")
}

model AuditLog {
  id           String         @id @default(cuid())
  tenantId     String?
  actorType    AuditActorType @default(system)
  actorId      String?
  action       String
  resourceType String?
  resourceId   String?
  payload      Json?
  createdAt    DateTime       @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model SecurityAlert {
  id             String    @id @default(cuid())
  tenantId       String?
  severity       String    @default("info")
  code           String
  message        String
  payload        Json?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, severity])
  @@map("security_alerts")
}

model SecretRef {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  provider  String
  reference String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("secrets_refs")
}

model PrivacyRequest {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  kind      String
  status    String   @default("open")
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@map("privacy_requests")
}

model Backup {
  id          String    @id @default(cuid())
  tenantId    String?
  kind        String
  status      String    @default("pending")
  storageRef  String?
  checksum    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([tenantId, status])
  @@map("backups")
}

model ChatSetting {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String?
  key       String
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chat   Chat?  @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([tenantId, chatId, key])
  @@map("chat_settings")
}

model ModerationCase {
  id            String   @id @default(cuid())
  tenantId      String
  chatId        String?
  caseNumber    Int
  subjectUserId String?
  status        String   @default("open")
  reason        String?
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chat   Chat?  @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([tenantId, caseNumber])
  @@index([tenantId, chatId])
  @@map("moderation_cases")
}

model Sanction {
  id        String       @id @default(cuid())
  tenantId  String
  caseId    String?
  userId    String
  kind      SanctionKind
  status    String       @default("active")
  reason    String?
  startsAt  DateTime     @default(now())
  endsAt    DateTime?
  payload   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@map("sanctions")
}

model Warning {
  id        String    @id @default(cuid())
  tenantId  String
  userId    String
  caseId    String?
  reason    String?
  weight    Int       @default(1)
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  expiredAt DateTime?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt, expiredAt])
  @@map("warnings")
}

model Report {
  id                String   @id @default(cuid())
  tenantId          String
  chatId            String?
  reporterUserId    String?
  subjectTelegramId BigInt
  reason            String?
  status            String   @default("open")
  createdAt         DateTime @default(now())

  @@index([tenantId, status])
  @@map("reports")
}

model Evidence {
  id         String   @id @default(cuid())
  tenantId   String
  caseId     String
  type       String
  storageRef String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([tenantId, caseId])
  @@map("evidence")
}

model Appeal {
  id         String   @id @default(cuid())
  tenantId   String
  caseId     String
  userId     String
  status     String   @default("open")
  message    String
  resolution String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, caseId, status])
  @@map("appeals")
}

model SpamProfile {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String?
  name      String
  threshold Int      @default(0)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, chatId, name])
  @@map("spam_profiles")
}

model AntifloodConfig {
  id              String   @id @default(cuid())
  tenantId        String
  chatId          String   @unique
  enabled         Boolean  @default(false)
  windowSeconds   Int      @default(10)
  messageLimit    Int      @default(5)
  action          String   @default("mute")
  muteSeconds     Int      @default(300)
  cooldownSeconds Int      @default(30)
  exempt          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("antiflood_configs")
}

model AntifloodEvent {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  telegramUserId BigInt
  messageCount   Int
  windowSeconds  Int
  action         String
  createdAt      DateTime @default(now())

  @@index([tenantId, chatId, createdAt])
  @@index([tenantId, telegramUserId])
  @@map("antiflood_events")
}

model AntiraidConfig {
  id                String    @id @default(cuid())
  tenantId          String
  chatId            String    @unique
  enabled           Boolean   @default(false)
  windowSeconds     Int       @default(30)
  joinLimit         Int       @default(5)
  mode              String    @default("observe")
  newAccountAgeDays Int       @default(0)
  underAttackUntil  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId])
  @@map("antiraid_configs")
}

model AntiraidEvent {
  id            String   @id @default(cuid())
  tenantId      String
  chatId        String
  joinCount     Int
  windowSeconds Int
  mode          String
  createdAt     DateTime @default(now())

  @@index([tenantId, chatId, createdAt])
  @@map("antiraid_events")
}

model Note {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  name      String
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, name])
  @@index([tenantId, chatId])
  @@map("notes")
}

model StaffNote {
  id               String   @id @default(cuid())
  tenantId         String
  chatId           String
  authorTelegramId BigInt?
  authorName       String?
  text             String
  createdAt        DateTime @default(now())

  @@index([tenantId, chatId])
  @@map("staff_notes")
}

model EconomyWallet {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  userTelegramId BigInt
  balance        Int      @default(0)
  lastEarnedMs   BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, chatId, userTelegramId])
  @@map("economy_wallets")
}

model Incident {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  title     String
  status    String   @default("investigando")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, chatId])
  @@map("incidents")
}

model CoopMissionState {
  id          String   @id @default(cuid())
  tenantId    String
  chatId      String
  goal        Int      @default(0)
  progress    Int      @default(0)
  description String   @default("")
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, chatId])
  @@map("coop_missions")
}

model GratitudePoint {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  userTelegramId BigInt
  points         Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, chatId, userTelegramId])
  @@index([tenantId, chatId])
  @@map("gratitude_points")
}

model CustomCommand {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  name      String
  response  String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, name])
  @@index([tenantId, chatId])
  @@map("custom_commands")
}

model Filter {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  trigger   String
  response  String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, trigger])
  @@index([tenantId, chatId])
  @@map("filters")
}

model Poll {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  question  String
  options   Json
  closed    Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes PollVote[]

  @@index([tenantId, chatId])
  @@map("polls")
}

model PollVote {
  id             String   @id @default(cuid())
  pollId         String
  telegramUserId BigInt
  optionIndex    Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, telegramUserId])
  @@index([pollId])
  @@map("poll_votes")
}

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  chatId    String
  productId String
  title     String
  amount    Int
  currency  String   @default("XTR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, productId])
  @@index([tenantId, chatId])
  @@map("products")
}

model Invoice {
  id             String   @id @default(cuid())
  tenantId       String
  chatId         String
  productId      String
  telegramUserId BigInt
  payload        String
  amount         Int
  currency       String   @default("XTR")
  status         String   @default("created")
  createdAt      DateTime @default(now())

  @@index([tenantId, chatId])
  @@map("invoices")
