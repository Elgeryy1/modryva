  tenantId  String
  chatId    String?
  kind      String
  title     String
  body      String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, chatId, createdAt])
  @@index([tenantId, kind])
  @@map("d1_events")
}

model QuarantineConfig {
